{
  "$schema": "https://opencode.ai/config.json",
  "model": "proxypal/gpt-5.4",
  "permission": {
    "*": {
      "*": "allow",
    }
  },
  "provider": {
    "proxypal": {
      "models": {
        "gpt-5.4": {
          "limit": {
            "context": 400000,
            "output": 32768
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "name": "Gpt 5 4",
          "options": {
            "reasoningEffort": "xhigh"
          },
          "reasoning": true,
          "variants": {
            "high": {
              "reasoningEffort": "high"
            },
            "xhigh": {
              "reasoningEffort": "xhigh"
            }
          }
        }
      },
      "name": "ProxyPal",
      "npm": "@ai-sdk/anthropic",
      "options": {
        "apiKey": "proxypal-local",
        "baseURL": "http://127.0.0.1:8317/v1",
        "includeUsage": true
      }
    }
  }
}
